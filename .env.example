# Copy this file to ".env" and fill in the real values.
# NEVER commit the real .env (see .gitignore).

# Graph API version (leave as-is unless Meta deprecates it)
GRAPH_VERSION=v21.0

# --- Facebook Page ---
# Numeric Page ID (Business Suite > Settings, or graph.facebook.com/me/accounts)
FB_PAGE_ID=
# Long-lived PAGE access token. Easiest: fill the FB_APP_* + FB_USER_TOKEN below
# and run `node refresh-token.mjs`, which fills this in for you.
FB_PAGE_TOKEN=

# --- Instagram (only needed if posting to IG) ---
# IG Business account ID (linked to the Page above)
IG_USER_ID=
# Usually leave blank — IG publishing reuses FB_PAGE_TOKEN.
IG_TOKEN=

# --- For refresh-token.mjs (one-time, to get a non-expiring Page token) ---
# App dashboard > Settings > Basic
FB_APP_ID=
FB_APP_SECRET=
# Graph API Explorer: "User or Page" = User Token, Generate, paste here. Short-lived OK.
# refresh-token.mjs consumes this and clears it.
FB_USER_TOKEN=

# --- Image hosting for Instagram (auto-convert webp/png/local -> public JPEG) ---
ASSET_BASE_URL=https://assets.frontlinewebdesign.tech
ASSET_REMOTE_DIR=domains/frontlinewebdesign.tech/public_html/assets
# hPanel > Files > FTP Accounts
FTP_HOST=
FTP_USER=
FTP_PASS=
FTP_SECURE=false
# Optional: path to python (Pillow must be installed: pip install Pillow)
PYTHON=python

# --- pull-leads.mjs: email new Instant Form leads (optional) ---
# Hostinger SMTP (hPanel > Emails). Leave blank to just save leads to leads.csv.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
LEAD_FROM=
LEAD_TO=
